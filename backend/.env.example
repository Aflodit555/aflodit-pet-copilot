# AFlodit Pet Copilot backend env example

# v0.6.2 Latency Trace & Prompt Slimming
MODEL_PROVIDER=mock
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=
MODEL_TIMEOUT_MS=20000
MODEL_TEMPERATURE=0.3
MODEL_MAX_TOKENS=512
# Optional. Set to json_object only if your provider supports OpenAI response_format.
MODEL_RESPONSE_FORMAT=
LLM_DEBUG=false

# Local backend
HOST=127.0.0.1
PORT=3001

# 0 means no backend reply truncation
MAX_REPLY_CHARS=0

# Stability controls
DEBUG_LOG=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Local request token. Must match content.js Config.localClientToken.
LOCAL_CLIENT_TOKEN=aflodit-pet-local-dev

# CORS options. Usually leave these empty in local dev.
CORS_ALLOW_ALL=false
CORS_ALLOWED_ORIGINS=
