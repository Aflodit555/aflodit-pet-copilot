{
  "manifest_version": 3,
  "name": "AFlodit Pet Copilot",
  "version": "0.7.0.11",
  "description": "A lightweight browser pet AI assistant.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["pet.css"],
      "run_at": "document_idle"
    }
  ]
}
